# Supabase (https://supabase.com/dashboard) — copier les vraies valeurs depuis Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
# Clé service : uniquement côté serveur, jamais exposée au client (Dashboard → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret

# API
PORT=3000
NODE_ENV=development

# Rate limiting (par adresse IP, mémoire process — derrière plusieurs instances, prévoir Redis plus tard)
# RATE_LIMIT_MAX=300
# RATE_LIMIT_WINDOW_MS=900000
# Requêtes / minute max sur /api/v1 (0 = désactivé)
# RATE_LIMIT_API_PER_MINUTE=90

# Optionnel : origines CORS séparées par des virgules (en production, les POST depuis
# un navigateur doivent envoyer un Origin présent dans cette liste — mitigation CSRF)
# CORS_ORIGINS=https://ton-app.example,http://localhost:5173

# mock = dépôts/retraits complétés tout de suite (développement). live = transactions pending jusqu’au webhook opérateur
PAYMENT_MODE=mock

# Frais de retrait fixe (Ariary)
WITHDRAWAL_FEE_AR=500

# Bonus premier dépôt avec code promo (%)
PROMO_FIRST_DEPOSIT_PERCENT=20

# Seuil de progression pour débloquer les retraits si promo (% de l'objectif)
PROMO_WITHDRAWAL_MIN_PROGRESS_PERCENT=80
