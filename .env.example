# Supabase (https://supabase.com/dashboard)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
# Clé service : uniquement côté serveur, jamais exposée au client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# API
PORT=3000
NODE_ENV=development

# Optionnel : origines CORS séparées par des virgules
# CORS_ORIGINS=http://localhost:5173

# mock = dépôts/retraits complétés tout de suite (développement). live = transactions pending jusqu’au webhook opérateur
PAYMENT_MODE=mock

# Frais de retrait fixe (Ariary)
WITHDRAWAL_FEE_AR=500

# Bonus premier dépôt avec code promo (%)
PROMO_FIRST_DEPOSIT_PERCENT=20

# Seuil de progression pour débloquer les retraits si promo (% de l'objectif)
PROMO_WITHDRAWAL_MIN_PROGRESS_PERCENT=80
